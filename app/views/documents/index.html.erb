<div class="min-h-screen bg-gray-50">
  <div class="container mx-auto px-4 py-8">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Document Library</h1>
        <p class="text-gray-600 mt-2">Upload, manage, and query your documents</p>
      </div>
      <%= link_to new_document_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg shadow-md transition duration-150 ease-in-out flex items-center" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Upload Document
      <% end %>
    </div>

    <!-- Chat Interface -->
    <div class="bg-white rounded-xl shadow-lg p-6 mb-8">
      <div class="flex flex-col h-[500px]">
        <!-- Chat Messages Area -->
        <div class="flex-1 overflow-y-auto mb-4 p-4 bg-gray-50 rounded-lg" id="chat-messages">
          <% if @answer.present? %>
            <!-- User Query -->
            <div class="flex justify-end mb-4">
              <div class="bg-blue-100 text-blue-800 rounded-lg py-2 px-4 max-w-[80%]">
                <p class="text-sm"><%= params[:query] %></p>
                <p class="text-xs text-blue-600 mt-1">You</p>
              </div>
            </div>
            
            <!-- AI Response -->
            <div class="flex justify-start mb-4">
              <div class="bg-white shadow-sm rounded-lg py-3 px-4 max-w-[80%]">
                <div class="prose prose-sm">
                  <%= @answer %>
                </div>
                <% if @relevant_docs.present? %>
                  <div class="mt-3 pt-3 border-t border-gray-200">
                    <p class="text-xs font-semibold text-gray-600 mb-2">Sources:</p>
                    <ul class="text-xs text-blue-600 space-y-1">
                      <% @relevant_docs.each do |doc| %>
                        <li>
                          <%= link_to doc.title, document_path(doc), class: "hover:underline" %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>
                <p class="text-xs text-gray-500 mt-1">AI Assistant</p>
              </div>
            </div>
          <% else %>
            <div class="h-full flex items-center justify-center">
              <div class="text-center text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                </svg>
                <p class="text-lg font-medium">Ask anything about your documents</p>
                <p class="mt-2">Your AI assistant will help you find the information you need</p>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Query Input -->
        <%= form_with url: query_documents_path, method: :get, class: "flex gap-3", local: true do |f| %>
          <%= f.text_field :query,
              placeholder: "Ask a question about your documents...",
              class: "flex-1 rounded-lg border-gray-300 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              autocomplete: "off" %>
          <%= f.button type: "submit", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg shadow-sm transition duration-150 ease-in-out" do %>
            <span class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
              Ask
            </span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Documents Grid -->
    <div class="space-y-6">
      <h2 class="text-2xl font-semibold text-gray-900">Your Documents</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @documents.each do |document| %>
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition duration-150 ease-in-out">
            <div class="p-6">
              <div class="flex items-center mb-4">
                <div class="bg-blue-100 rounded-lg p-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div class="ml-4">
                  <h3 class="text-lg font-semibold text-gray-900"><%= document.title %></h3>
                  <p class="text-sm text-gray-500">Uploaded <%= time_ago_in_words(document.created_at) %> ago</p>
                </div>
              </div>
              <div class="flex justify-between items-center mt-4">
                <%= link_to document_path(document), class: "text-blue-600 hover:text-blue-800 font-medium text-sm" do %>
                  View Details
                  <span aria-hidden="true"> &rarr;</span>
                <% end %>
                <%= button_to document_path(document),
                    method: :delete,
                    class: "text-red-600 hover:text-red-800 font-medium text-sm",
                    data: { 
                      turbo_confirm: "Are you sure you want to delete this document? This action cannot be undone.",
                      turbo_method: :delete
                    } do %>
                  Delete
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
