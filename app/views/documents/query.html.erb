<!-- Query Results Page -->
<div class="min-h-screen bg-gray-50 py-8">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center justify-between">
          <div>
            <div class="flex items-center">
              <%= link_to documents_path, class: "text-blue-600 hover:text-blue-800 mr-4" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
              <% end %>
              <h1 class="text-3xl font-bold text-gray-900">Query Results</h1>
            </div>
            <p class="mt-2 text-gray-600">Results for: "<%= params[:query] %>"</p>
          </div>
        </div>
      </div>

      <!-- Results Card -->
      <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <!-- AI Response -->
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Answer</h2>
          <div class="prose prose-blue max-w-none">
            <%= @answer %>
          </div>
        </div>

        <!-- Relevant Documents -->
        <% if @relevant_docs.present? %>
          <div class="p-6 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Relevant Documents</h2>
            <div class="space-y-4">
              <% @relevant_docs.each do |doc| %>
                <div class="bg-white rounded-lg shadow p-4">
                  <div class="flex items-start">
                    <div class="flex-shrink-0">
                      <svg class="h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    <div class="ml-4">
                      <h3 class="text-lg font-medium text-gray-900">
                        <%= link_to doc.title, document_path(doc), class: "hover:text-blue-600" %>
                      </h3>
                      <p class="mt-1 text-sm text-gray-500">
                        <%= truncate(doc.content, length: 200) %>
                      </p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- New Query Form -->
        <div class="p-6 border-t border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Ask Another Question</h2>
          <%= form_with url: query_documents_path, method: :get, class: "flex gap-3", local: true do |f| %>
            <%= f.text_field :query,
                placeholder: "Ask a new question...",
                class: "flex-1 rounded-lg border-gray-300 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
            <%= f.button type: "submit", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg shadow-sm transition duration-150 ease-in-out" do %>
              <span class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                Ask
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
